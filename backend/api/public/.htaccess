<IfModule mod_rewrite.c>
    RewriteEngine On

    # Si le fichier/dossier existe, Apache le sert directement
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Sinon, on envoie tout vers Symfony
    RewriteRule ^ index.php [L]
</IfModule>